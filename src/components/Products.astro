---
import portfolioData from "../data/portfolio.json";

const { products } = portfolioData;
const showProducts = false; // Set to true when products/SaaS are ready to be shown
---

<div class="panel-products">
  {showProducts ? (
    <div class="products-stacked-list">
      {products.map((product) => (
        <div class="product-stacked-card">
          <div class="product-stacked-header">
            <div class="product-stacked-title-group">
              <span class="product-stacked-badge">{product.paymentType}</span>
              <h4 class="product-stacked-title">{product.title}</h4>
            </div>
            <span class="product-stacked-price">{product.price}</span>
          </div>
          
          <p class="product-stacked-desc">{product.description}</p>
          
          <ul class="product-stacked-features">
            {product.features.map((feature) => (
              <li>
                <i class="fas fa-check"></i>
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <div class="product-stacked-action">
            <a href={product.link} target="_blank" rel="noopener noreferrer" class="btn btn-primary product-cv-btn">
              Saber más / Adquirir <i class="fas fa-arrow-up-right-from-square"></i>
            </a>
          </div>
        </div>
      ))}
    </div>
  ) : (
    <div class="products-construction">
      <div class="construction-icon-wrapper">
        <i class="fas fa-screwdriver-wrench construction-icon"></i>
      </div>
      <h3 class="construction-title">Sección en Construcción</h3>
      <p class="construction-text">
        Actualmente me encuentro planificando y desarrollando herramientas de software y plataformas SaaS.
        ¡Pronto verás mis productos disponibles aquí!
      </p>
      <div class="construction-divider"></div>
      <p class="construction-footer">
        ¿Tienes una propuesta o necesitas software a medida?
      </p>
      <button class="btn btn-primary btn-contact-redirect" id="btn-construction-contact">
        <i class="fas fa-paper-plane"></i> Contactar ahora
      </button>
    </div>
  )}
</div>

<script>
  const setupConstructionRedirect = () => {
    const contactRedirectBtn = document.getElementById('btn-construction-contact');
    if (contactRedirectBtn) {
      contactRedirectBtn.addEventListener('click', () => {
        const contactBtn = document.querySelector('.linktree-btn[data-tab="contact"]') as HTMLButtonElement | null;
        if (contactBtn) {
          contactBtn.click();
        }
      });
    }
  };

  // Run on initial load
  setupConstructionRedirect();
  // Run on Astro page transitions
  document.addEventListener('astro:after-swap', setupConstructionRedirect);
</script>

<style>
  .panel-products {
    display: flex;
    flex-direction: column;
  }

  .products-stacked-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-stacked-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color var(--transition-speed) ease;
  }

  .product-stacked-card:hover {
    border-color: var(--text-muted);
  }

  .product-stacked-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .product-stacked-title-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    align-items: flex-start;
  }

  .product-stacked-badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background-color: rgba(37, 99, 235, 0.1);
    color: var(--accent-blue);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    border: 1px solid rgba(37, 99, 235, 0.2);
  }

  .product-stacked-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .product-stacked-price {
    font-size: 1.4rem;
    font-family: var(--font-heading);
    font-weight: 800;
    color: var(--text-primary);
    white-space: nowrap;
  }

  .product-stacked-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .product-stacked-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    border-top: 1px solid var(--border-color);
    padding-top: 0.75rem;
  }

  .product-stacked-features li {
    font-size: 0.85rem;
    color: var(--text-secondary);
    display: flex;
    gap: 0.6rem;
    align-items: center;
  }

  .product-stacked-features li i {
    color: var(--accent-blue);
    font-size: 0.75rem;
  }

  .product-stacked-action {
    margin-top: 0.25rem;
  }

  .product-cv-btn {
    width: 100%;
    font-size: 0.85rem;
    padding: 0.55rem 1rem;
    gap: 0.5rem;
  }

  /* Construction Card Styles */
  .products-construction {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 1.5rem;
    background-color: var(--bg-hover);
    border: 1px dashed var(--accent-blue);
    border-radius: 12px;
    gap: 1.25rem;
    position: relative;
    overflow: hidden;
  }

  .products-construction::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(34, 197, 94, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .construction-icon-wrapper {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-blue);
    font-size: 1.75rem;
    box-shadow: 0 0 15px rgba(34, 197, 94, 0.15);
    animation: pulseGlow 2s infinite ease-in-out;
  }

  .construction-icon {
    animation: rotateWrench 4s infinite linear;
  }

  @keyframes pulseGlow {
    0%, 100% {
      transform: scale(1);
      box-shadow: 0 0 15px rgba(34, 197, 94, 0.15);
    }
    50% {
      transform: scale(1.05);
      box-shadow: 0 0 25px rgba(34, 197, 94, 0.35);
    }
  }

  @keyframes rotateWrench {
    0%, 100% {
      transform: rotate(0deg);
    }
    25% {
      transform: rotate(-15deg);
    }
    75% {
      transform: rotate(15deg);
    }
  }

  .construction-title {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .construction-text {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 400px;
    margin: 0;
  }

  .construction-divider {
    width: 60px;
    height: 1px;
    background-color: var(--border-color);
    margin: 0.5rem 0;
  }

  .construction-footer {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
    margin: 0;
  }

  .btn-contact-redirect {
    font-size: 0.85rem;
    padding: 0.55rem 1.25rem;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
</style>
