---
import portfolioData from "../data/portfolio.json";

const { email, phone, location } = portfolioData.personalInfo;
---

<section id="contact" class="section contact-section">
  <div class="contact-glow"></div>
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Contacto</h2>
      <div class="section-line"></div>
    </div>

    <div class="contact-grid">
      <!-- Contact Info Cards -->
      <div class="contact-info">
        <h3 class="contact-subtitle">¿Tienes un proyecto en mente?</h3>
        <p class="contact-text">
          Estoy disponible para conversar sobre oportunidades laborales, proyectos freelance o colaboraciones académicas. Envíame un mensaje y te responderé lo antes posible.
        </p>

        <div class="info-cards-list">
          <div class="info-card glass-card">
            <div class="info-icon"><i class="fas fa-envelope"></i></div>
            <div class="info-details">
              <span class="info-label">Email</span>
              <a href={`mailto:${email}`} class="info-link">{email}</a>
            </div>
          </div>

          <div class="info-card glass-card">
            <div class="info-icon"><i class="fas fa-phone"></i></div>
            <div class="info-details">
              <span class="info-label">Teléfono</span>
              <a href={`tel:${phone.replace(/\s+/g, '')}`} class="info-link">{phone}</a>
            </div>
          </div>

          <div class="info-card glass-card">
            <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
            <div class="info-details">
              <span class="info-label">Ubicación</span>
              <span class="info-value">{location}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-container glass-card">
        <form id="portfolio-contact-form" class="contact-form">
          <div class="form-row">
            <div class="input-group">
              <input type="text" id="form-name" required placeholder=" " />
              <label for="form-name">Nombre</label>
            </div>
            <div class="input-group">
              <input type="email" id="form-email" required placeholder=" " />
              <label for="form-email">Email</label>
            </div>
          </div>

          <div class="input-group">
            <input type="text" id="form-subject" required placeholder=" " />
            <label for="form-subject">Asunto</label>
          </div>

          <div class="input-group">
            <textarea id="form-message" required rows="5" placeholder=" "></textarea>
            <label for="form-message">Mensaje</label>
          </div>

          <button type="submit" class="btn btn-primary btn-submit">
            Enviar Mensaje <i class="fas fa-paper-plane"></i>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Custom Alert Toast -->
  <div id="contact-toast" class="contact-toast">
    <div class="toast-content">
      <i class="fas fa-circle-check toast-icon"></i>
      <div class="toast-message">
        <h4 class="toast-title">¡Mensaje Enviado!</h4>
        <p class="toast-desc">Gracias por contactarme. Te responderé a la brevedad.</p>
      </div>
    </div>
    <div class="toast-progress"></div>
  </div>
</section>

<style>
  .contact-section {
    background-color: var(--bg-tertiary);
    overflow: hidden;
  }

  .contact-glow {
    position: absolute;
    top: 20%;
    right: 20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.05) 0%, transparent 70%);
    z-index: 0;
    pointer-events: none;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 2.25rem;
    margin-bottom: 0.5rem;
  }

  .section-line {
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple));
    margin: 0 auto;
    border-radius: 2px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    position: relative;
    z-index: 1;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-subtitle {
    font-size: 1.75rem;
    font-weight: 700;
  }

  .contact-text {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .info-cards-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .info-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem;
  }

  .info-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent-blue);
  }

  .info-icon {
    width: 46px;
    height: 46px;
    border-radius: 10px;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: var(--accent-blue);
    flex-shrink: 0;
  }

  .info-card:hover .info-icon {
    background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-purple) 100%);
    color: #ffffff;
    border-color: transparent;
  }

  .info-details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .info-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .info-link, .info-value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .info-link:hover {
    color: var(--accent-teal);
  }

  /* Form Styling with Floating Labels */
  .contact-form-container {
    padding: 2.5rem;
  }

  .contact-form-container:hover {
    transform: none;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .input-group {
    position: relative;
    width: 100%;
  }

  .input-group input,
  .input-group textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: all var(--transition-speed) ease;
  }

  .input-group textarea {
    resize: none;
  }

  /* Floating labels */
  .input-group label {
    position: absolute;
    left: 1rem;
    top: 0.85rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    pointer-events: none;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .input-group input:focus,
  .input-group textarea:focus {
    border-color: var(--accent-purple);
    outline: none;
    box-shadow: 0 0 10px rgba(139, 92, 246, 0.25);
  }

  /* Moves label up when input has value or is focused */
  .input-group input:focus ~ label,
  .input-group input:not(:placeholder-shown) ~ label,
  .input-group textarea:focus ~ label,
  .input-group textarea:not(:placeholder-shown) ~ label {
    top: -0.65rem;
    left: 0.75rem;
    font-size: 0.75rem;
    padding: 0 0.4rem;
    background: var(--bg-secondary);
    color: var(--accent-purple);
    font-weight: 600;
    border-radius: 4px;
  }

  .btn-submit {
    align-self: flex-start;
    padding: 0.85rem 2rem;
    gap: 0.75rem;
  }

  /* Toast Notification styling */
  .contact-toast {
    position: fixed;
    bottom: 2rem;
    right: -400px;
    width: 360px;
    background: #0f172a;
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    z-index: 1000;
    overflow: hidden;
    transition: right 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .contact-toast.show {
    right: 2rem;
  }

  .toast-content {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem;
  }

  .toast-icon {
    font-size: 2rem;
    color: #22c55e;
  }

  .toast-message {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .toast-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #ffffff;
  }

  .toast-desc {
    font-size: 0.85rem;
    color: #94a3b8;
  }

  .toast-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    width: 100%;
    background-color: #22c55e;
  }

  .contact-toast.show .toast-progress {
    animation: toast-timer 4s linear forwards;
  }

  @keyframes toast-timer {
    from { width: 100%; }
    to { width: 0%; }
  }

  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 576px) {
    .form-row {
      grid-template-columns: 1fr;
    }
    
    .contact-form-container {
      padding: 1.5rem;
    }
    
    .btn-submit {
      width: 100%;
    }
    
    .contact-toast {
      width: calc(100% - 2rem);
      left: 1rem;
      right: 1rem;
      transform: translateY(150px);
      transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    
    .contact-toast.show {
      transform: translateY(0);
      left: 1rem;
      right: 1rem;
    }
  }
</style>

<script>
  const setupContactForm = () => {
    const form = document.getElementById('portfolio-contact-form');
    const toast = document.getElementById('contact-toast');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Reset form
      (form as HTMLFormElement).reset();

      // Show beautiful success Toast
      if (toast) {
        toast.classList.add('show');
        
        // Hide toast after 4 seconds
        setTimeout(() => {
          toast.classList.remove('show');
        }, 4000);
      }
    });
  };

  setupContactForm();
  document.addEventListener('astro:after-swap', setupContactForm);
</script>
