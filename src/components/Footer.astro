---
import portfolioData from "../data/portfolio.json";

const { name, lastName, email, github, linkedin } = portfolioData.personalInfo;
const currentYear = new Date().getFullYear();
---

<footer class="portfolio-footer">
  <div class="container footer-container">
    <!-- Footer Brand -->
    <div class="footer-brand">
      <a href="#" class="footer-logo">
        <span class="logo-accent">{name.charAt(0)}</span>{lastName.charAt(0)}
      </a>
      <p class="footer-tagline">Desarrollando soluciones web eficientes e innovadoras.</p>
    </div>

    <!-- Footer Middle Links -->
    <div class="footer-links">
      <a href="#about" class="footer-link">Sobre Mí</a>
      <a href="#skills" class="footer-link">Habilidades</a>
      <a href="#projects" class="footer-link">Proyectos</a>
      <a href="#contact" class="footer-link">Contacto</a>
    </div>

    <!-- Footer Socials & Copyright -->
    <div class="footer-end">
      <div class="footer-socials">
        <a href={github} target="_blank" rel="noopener noreferrer" class="footer-social-icon" aria-label="GitHub">
          <i class="fab fa-github"></i>
        </a>
        <a href={linkedin} target="_blank" rel="noopener noreferrer" class="footer-social-icon" aria-label="LinkedIn">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a href={`mailto:${email}`} class="footer-social-icon" aria-label="Email">
          <i class="fas fa-envelope"></i>
        </a>
      </div>
      <p class="footer-copyright">
        &copy; {currentYear} {name} {lastName}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>

<style>
  .portfolio-footer {
    background-color: var(--bg-primary);
    border-top: 1px solid var(--border-color);
    padding: 4rem 0 2.5rem 0;
    position: relative;
    z-index: 1;
  }

  .footer-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    text-align: center;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-logo {
    font-size: 2rem;
    font-family: var(--font-heading);
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -1px;
  }

  .logo-accent {
    background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-purple) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-tagline {
    font-size: 0.95rem;
    color: var(--text-muted);
    max-width: 300px;
  }

  .footer-links {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-link {
    font-size: 0.9rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .footer-link:hover {
    color: var(--accent-teal);
  }

  .footer-end {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    border-top: 1px solid var(--border-color);
    padding-top: 2rem;
  }

  .footer-socials {
    display: flex;
    gap: 1.25rem;
  }

  .footer-social-icon {
    font-size: 1.25rem;
    color: var(--text-muted);
    transition: all var(--transition-speed) ease;
  }

  .footer-social-icon:hover {
    color: var(--text-primary);
    transform: translateY(-2px);
  }

  .footer-social-icon:nth-child(1):hover { color: var(--accent-blue); }
  .footer-social-icon:nth-child(2):hover { color: var(--accent-purple); }
  .footer-social-icon:nth-child(3):hover { color: var(--accent-teal); }

  .footer-copyright {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 576px) {
    .footer-links {
      gap: 1.5rem;
    }
  }
</style>
