---
import portfolioData from "../data/portfolio.json";

const { github, linkedin, instagram, facebook } = portfolioData.personalInfo;

const socialLinks = [
  { name: "GitHub", url: github, icon: "fab fa-github" },
  { name: "LinkedIn", url: linkedin, icon: "fab fa-linkedin-in" },
  { name: "Instagram", url: instagram, icon: "fab fa-instagram" },
  { name: "Facebook", url: facebook, icon: "fab fa-facebook-f" }
];
---

<div class="panel-socials">
  <div class="socials-grid">
    {socialLinks.map((social) => (
      <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-card">
        <div class="social-card-icon">
          <i class={social.icon}></i>
        </div>
        <span class="social-card-name">{social.name}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .panel-socials {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .socials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    width: 100%;
  }

  .social-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-decoration: none;
    transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .social-card-icon {
    font-size: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 56px;
    width: 56px;
    border-radius: 50%;
    background-color: var(--bg-body);
    border: 1px solid var(--border-color);
    transition: all var(--transition-speed) ease;
    color: var(--text-secondary);
  }

  .social-card-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  /* Custom Hover Effects matching page palette */
  .social-card:hover {
    background-color: var(--bg-hover);
    transform: translateY(-3px);
  }

  .social-card:hover .social-card-icon {
    background-color: var(--bg-card);
    transform: scale(1.05);
  }

  /* GitHub Hover */
  .social-card:nth-child(1):hover {
    border-color: rgba(241, 247, 244, 0.3);
    box-shadow: 0 10px 15px -3px rgba(241, 247, 244, 0.05);
  }
  .social-card:nth-child(1):hover .social-card-icon {
    border-color: var(--text-primary);
    color: var(--text-primary);
    box-shadow: 0 0 12px rgba(241, 247, 244, 0.15);
  }

  /* LinkedIn Hover */
  .social-card:nth-child(2):hover {
    border-color: rgba(34, 197, 94, 0.3);
    box-shadow: 0 10px 15px -3px rgba(34, 197, 94, 0.08);
  }
  .social-card:nth-child(2):hover .social-card-icon {
    border-color: var(--accent-blue);
    color: var(--accent-blue);
    box-shadow: 0 0 12px rgba(34, 197, 94, 0.2);
  }

  /* Instagram Hover */
  .social-card:nth-child(3):hover {
    border-color: rgba(52, 211, 153, 0.3);
    box-shadow: 0 10px 15px -3px rgba(52, 211, 153, 0.08);
  }
  .social-card:nth-child(3):hover .social-card-icon {
    border-color: var(--accent-teal);
    color: var(--accent-teal);
    box-shadow: 0 0 12px rgba(52, 211, 153, 0.2);
  }

  /* Facebook Hover */
  .social-card:nth-child(4):hover {
    border-color: rgba(16, 185, 129, 0.3);
    box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.08);
  }
  .social-card:nth-child(4):hover .social-card-icon {
    border-color: var(--accent-purple);
    color: var(--accent-purple);
    box-shadow: 0 0 12px rgba(16, 185, 129, 0.2);
  }
</style>
