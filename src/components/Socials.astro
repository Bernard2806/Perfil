---
import portfolioData from "../data/portfolio.json";

const { github, linkedin, instagram, facebook } = portfolioData.personalInfo;

const socialLinks = [
  { name: "GitHub", url: github, icon: "fab fa-github", color: "#f1f7f4" },
  { name: "LinkedIn", url: linkedin, icon: "fab fa-linkedin-in", color: "#0077b5" },
  { name: "Instagram", url: instagram, icon: "fab fa-instagram", color: "#e1306c" },
  { name: "Facebook", url: facebook, icon: "fab fa-facebook-f", color: "#1877f2" }
];
---

<div class="panel-socials">
  <div class="socials-grid">
    {socialLinks.map((social) => (
      <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-card">
        <div class="social-card-icon">
          <i class={social.icon} style={`color: ${social.color};`}></i>
        </div>
        <span class="social-card-name">{social.name}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .panel-socials {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .socials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    width: 100%;
  }

  .social-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-decoration: none;
    transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .social-card:hover {
    border-color: var(--border-color-hover);
    background-color: var(--bg-hover);
    transform: translateY(-3px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
  }

  .social-card-icon {
    font-size: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 60px;
    width: 60px;
    border-radius: 50%;
    background-color: var(--bg-body);
    border: 1px solid var(--border-color);
    transition: all var(--transition-speed) ease;
  }

  .social-card:hover .social-card-icon {
    border-color: var(--accent-blue);
    transform: scale(1.05);
  }

  .social-card-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text-primary);
  }
</style>
