---
// Education.astro
---

<div class="panel-education">
  <h4 class="edu-section-title">Educación Formal</h4>
  
  <div class="edu-timeline">
    <!-- University -->
    <div class="edu-item">
      <div class="edu-icon">
        <i class="fas fa-university"></i>
      </div>
      <div class="edu-details">
        <h4 class="edu-title">Universidad Nacional de Luján (UNLu)</h4>
        <p class="edu-degree">Licenciatura en Sistemas</p>
        <span class="edu-period">Cursando (Ingreso 2026) • Duración estimada: 5 años</span>
      </div>
    </div>

    <!-- Cybersecurity Diploma -->
    <div class="edu-item">
      <div class="edu-icon">
        <i class="fas fa-shield-alt"></i>
      </div>
      <div class="edu-details">
        <h4 class="edu-title">UNTREF — Centro Universitario de Chivilcoy (CUCH)</h4>
        <p class="edu-degree">Diplomatura en Ciberseguridad</p>
        <span class="edu-period">Cursando (2026) • Duración: 1 año</span>
      </div>
    </div>

    <!-- Programming Technician (UTN) -->
    <div class="edu-item">
      <div class="edu-icon">
        <i class="fas fa-code"></i>
      </div>
      <div class="edu-details">
        <h4 class="edu-title">UTN San Nicolás — Extensión Aula Chivilcoy (CUCH)</h4>
        <p class="edu-degree">Tecnicatura Universitaria en Programación</p>
        <span class="edu-period">Cursado 1° año (2025) • Duración: 2 años (Incompleto)</span>
      </div>
    </div>

    <!-- Secondary School -->
    <div class="edu-item">
      <div class="edu-icon">
        <i class="fas fa-school"></i>
      </div>
      <div class="edu-details">
        <h4 class="edu-title">Escuela Secundaria Técnica N°1 "Mariano Moreno"</h4>
        <p class="edu-degree">Técnico en Informática</p>
        <span class="edu-period">Egresado en 2024</span>
      </div>
    </div>
  </div>

  <h4 class="edu-section-title section-courses">Cursos y Certificaciones</h4>
  
  <div class="courses-grid">
    <!-- Azure -->
    <div class="course-card">
      <div class="course-icon">
        <i class="fas fa-certificate"></i>
      </div>
      <div class="course-details">
        <h5 class="course-title">Azure</h5>
        <p class="course-provider">ITSCHOOL - Educación IT</p>
        <span class="course-period">Expedido: Jun 2025</span>
      </div>
    </div>

    <!-- .NET -->
    <div class="course-card">
      <div class="course-icon">
        <i class="fas fa-certificate"></i>
      </div>
      <div class="course-details">
        <h5 class="course-title">.NET</h5>
        <p class="course-provider">ITSCHOOL - Educación IT</p>
        <span class="course-period">Expedido: Oct 2024</span>
      </div>
    </div>

    <!-- Videojuego -->
    <div class="course-card">
      <div class="course-icon">
        <i class="fas fa-gamepad"></i>
      </div>
      <div class="course-details">
        <h5 class="course-title">Tu Primer Videojuego</h5>
        <p class="course-provider">UNTREF – CUCH</p>
        <span class="course-period">Realizado</span>
      </div>
    </div>
  </div>
</div>

<style>
  .panel-education {
    display: flex;
    flex-direction: column;
  }

  .edu-section-title {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .edu-section-title.section-courses {
    margin-top: 2rem;
  }

  .edu-section-title::after {
    content: "";
    flex-grow: 1;
    height: 1px;
    background-color: var(--border-color);
  }

  .edu-timeline {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    position: relative;
  }

  /* Vertical line connecting the timeline items */
  .edu-timeline::before {
    content: "";
    position: absolute;
    left: 19px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background-color: var(--border-color);
    z-index: 0;
  }

  .edu-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .edu-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background-color: var(--bg-card);
    border: 2px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    color: var(--accent-blue);
    flex-shrink: 0;
    transition: all var(--transition-speed) ease;
  }

  .edu-item:hover .edu-icon {
    border-color: var(--accent-blue);
    color: var(--text-primary);
    background-color: var(--bg-hover);
    transform: scale(1.1);
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.2);
  }

  .edu-details {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .edu-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .edu-degree {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent-teal);
  }

  .edu-period {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Cursos section styling */
  .courses-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 480px) {
    .courses-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .course-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1rem;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    transition: all var(--transition-speed) ease;
  }

  .course-card:hover {
    border-color: var(--accent-teal);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(52, 211, 153, 0.05);
  }

  .course-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background-color: var(--bg-body);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-teal);
    font-size: 0.95rem;
    flex-shrink: 0;
    transition: all var(--transition-speed) ease;
  }

  .course-card:hover .course-icon {
    background-color: var(--accent-teal);
    color: var(--bg-card);
    border-color: var(--accent-teal);
  }

  .course-details {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .course-title {
    font-family: var(--font-heading);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .course-provider {
    font-size: 0.78rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .course-period {
    font-size: 0.72rem;
    color: var(--text-muted);
  }
</style>
